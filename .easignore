# .easignore — controls what `eas build` uploads (replaces .gitignore for the
# upload). We need it because `@fressh/react-native-terminal`'s codegen + native
# libs are GITIGNORED build artifacts that turbo produces in the working tree
# (cargo/ubrn/nitrogen). A plain git archive omits them, so eas build's JS bundle
# fails ("Unable to resolve ./generated/shim_uniffi") and the native link would
# fail too. The `!` rules at the bottom re-include those turbo outputs.
# See docs/projects/ci-building-and-releasing.md + build-reference/easignore.

# --- dependencies ---
node_modules/
**/node_modules/
.pnp
.pnp.js
.direnv/
.cache/

# --- vcs / tooling caches ---
.git/
.turbo/
**/.turbo/
**/tsconfig.tsbuildinfo
**/*.tsbuildinfo

# --- huge vendored docs clones (gigabytes) ---
docs/cloned-repos-as-docs/

# --- build outputs (regenerated) ---
**/dist/
**/.expo/
**/.next/
**/out/
**/.nitro/
**/.output/
**/.vercel/
coverage/
apps/mobile/build/
apps/mobile/web-build/
apps/mobile/expo-env.d.ts

# CNG native dirs — eas build runs prebuild itself, so don't ship stale copies
apps/mobile/android/
apps/mobile/ios/

# --- Rust build outputs (rust/target is ~2.9 GB) ---
**/rust/target/
packages/react-native-terminal/rust/vendor/alacritty/target/
packages/react-native-terminal/rust/vendor/crossfont/target/

# --- react-native-terminal build outputs ---
packages/react-native-terminal/lib/
packages/react-native-terminal/android/build/
packages/react-native-terminal/android/.cxx/
packages/react-native-terminal/ios/build/
# shim_uniffi.xcframework is a 114 MB build output (iOS only). The committed ANGLE
# xcframeworks (libEGL/libGLESv2) are NOT excluded — they're needed for iOS.
packages/react-native-terminal/shim_uniffi.xcframework/

# --- misc ---
.DS_Store
*.pem
*.log
npm-debug.*
yarn-debug.*
yarn-error.*
tmp/
mnt/*

# ============================================================================
# Re-include turbo-generated native artifacts (untracked but required for the
# build). MUST be last so these negations win. These dirs have SUBDIRECTORIES,
# so each needs both the dir negation AND a recursive `/**` — a bare `!dir/`
# re-includes only direct children, not files in nested subdirs (that's why a
# flat `!src/generated/` worked but nested `nitrogen/generated/` did not).
# ============================================================================
!packages/react-native-terminal/src/generated/
!packages/react-native-terminal/src/generated/**
!packages/react-native-terminal/cpp/generated/
!packages/react-native-terminal/cpp/generated/**
!packages/react-native-terminal/nitrogen/generated/
!packages/react-native-terminal/nitrogen/generated/**
!packages/react-native-terminal/android/generated/
!packages/react-native-terminal/android/generated/**
!packages/react-native-terminal/android/src/main/jniLibs/
!packages/react-native-terminal/android/src/main/jniLibs/**
