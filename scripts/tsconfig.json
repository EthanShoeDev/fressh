{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ESNext"],
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["node"],
		// Build/CLI scripts are tooling, not shipped Effect code — keep the
		// Effect LS for editor help but don't enforce its diagnostics as errors.
		"plugins": [{ "name": "@effect/language-service", "diagnostics": false }]
	},
	"include": ["**/*.ts"]
}
