{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"paths": {
			"@/*": ["./src/*"]
		},
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022"
	},
	"include": ["**/*"],
	"exclude": [".output", "dist"]
}
