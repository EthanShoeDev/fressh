# fastlane lanes for fressh mobile (Track B — no EAS, no match).
# See docs/projects/ci-building-and-releasing.md.
#
#   fastlane ios certs        one-time/renewal: create dist cert + profile via the ASC
#                             API key (then store them in OpenBao — runbook section D)
#   fastlane ios build        archive signed IPA -> build/fressh-ios.ipa (prebuild must have run)
#   fastlane ios beta         upload the IPA to TestFlight (internal testers)
#   fastlane ios release      submit the already-uploaded TestFlight build for App Review (promote)
#   fastlane android beta     upload build/fressh-android.aab to the Play internal track
#   fastlane android promote  promote a versionCode from internal -> production track
#
# iOS signing material is NOT in a match git repo — it lives in OpenBao (and as
# GitHub Secrets for CI) exactly like the Android keystore: the dist cert+key
# (FRESSH_IOS_CERT_P12_BASE64) and provisioning profile
# (FRESSH_IOS_PROFILE_BASE64) arrive as env vars via secretspec and are
# materialized/imported at build time.
#
# All file paths are absolute via MOBILE_DIR so lane behavior never depends on
# fastlane's working-directory rules.

require "base64"
require "fileutils"
require "json"
require "googleauth"
require "googleauth/external_account"

# BACKPORT — delete once nixpkgs ships fastlane >= 2.234.0.
# supply < 2.234.0 assumes json_key is a service-account key and dies with
# "missing client_email" on the external_account credentials file that
# google-github-actions/auth (WIF) writes. fastlane PR #29982 (in 2.234.0,
# https://github.com/fastlane/fastlane/pull/29982) dispatches on the JSON's
# "type"; replicate that at the one make_creds call
# supply's client performs. googleauth 1.8.1 already understands
# external_account — only supply's hardcoded credential class is the problem.
module SupplyExternalAccountBackport
  def make_creds(options = {})
    io = options[:json_key_io]
    if io
      type = begin
        JSON.parse(io.read)["type"]
      rescue JSON::ParserError
        nil
      end
      io.rewind
      return Google::Auth::ExternalAccount::Credentials.make_creds(options) if type == "external_account"
    end
    super
  end
end
Google::Auth::ServiceAccountCredentials.singleton_class.prepend(SupplyExternalAccountBackport)

MOBILE_DIR = File.expand_path("..", __dir__)
SIGNING_DIR = File.join(MOBILE_DIR, "build", "ios-signing")

# Name we give the App Store provisioning profile at creation (non-secret;
# referenced again at build time to pin xcode's manual signing to it).
IOS_PROFILE_NAME = "fressh appstore"
# The .p12's password. Not load-bearing secrecy — the p12 BLOB is the secret
# (in OpenBao/GH); a non-empty password + legacy ciphers exist only because
# macOS `security import` rejects OpenSSL-3-default/passwordless bundles.
IOS_P12_PASSWORD = "fressh-dist"

# App Store Connect API key + team. These are non-secret identifiers (fill
# once the key exists — runbook section D); only the .p8 content is secret and
# arrives via secretspec as ASC_API_KEY_P8.
ASC_KEY_ID = "RR3K2Q9Y5L"
ASC_ISSUER_ID = "69a6de93-97b3-47e3-e053-5b8c7c11a4d1"
APPLE_TEAM_ID = "9R7S3L2R7N"

def asc_api_key
  app_store_connect_api_key(
    key_id: ASC_KEY_ID,
    issuer_id: ASC_ISSUER_ID,
    key_content: ENV.fetch("ASC_API_KEY_P8"),
  )
end

def app_version
  JSON.parse(File.read(File.join(MOBILE_DIR, "package.json")))["version"]
end

# The marketing version (CFBundleShortVersionString / Android versionName) is a plain
# dotted triple — strip any changeset prerelease/snapshot suffix ("0.1.0-canary-abc"
# / "0.2.0-rc.0" -> "0.1.0" / "0.2.0"), matching marketingVersion in app.config.ts.
def marketing_version(version = app_version)
  version.split("-").first
end

# Android versionCode for STABLE releases + the offline/local iOS buildNumber default.
# MUST stay in sync with semverToCode in app.config.ts. Canary/rc builds instead get a
# store-derived, monotonic versionCode via FRESSH_VERSION_CODE (Android: see the
# android next_version_code lane); iOS ALWAYS overrides its build number from ASC
# (latest_ios_build_number below), so this is only Android's stable basis + iOS's
# offline default.
def version_code(version = marketing_version)
  maj, min, pat = version.split("-").first.split(".").map(&:to_i)
  maj * 10_000 + min * 100 + pat
end

# Highest CFBundleVersion already on TestFlight for this marketing version (0 if none).
# fastlane's documented build-number basis — increment_build_number(build_number:
# latest_testflight_build_number + 1). Queries App Store Connect via the ASC API key
# (token-only, no 2FA), so it self-corrects across CI re-runs; scoping to the marketing
# version makes +1 unique WITHIN that version (Apple's uniqueness rule). Works for
# stable, canary, and rc alike. app_identifier comes from the Appfile.
def latest_ios_build_number(version = marketing_version)
  latest_testflight_build_number(
    api_key: asc_api_key,
    version: version,
    initial_build_number: 0,
  )
end

# Release notes produced by `bun scripts/changelog-extract.ts` (the version's
# CHANGELOG.md section). Falls back to a stub for ad-hoc local runs.
def release_notes
  path = File.join(MOBILE_DIR, "build", "release-notes.txt")
  File.exist?(path) ? File.read(path) : "Internal build #{app_version}"
end

# Google Play auth, in preference order:
#  1. Workload Identity Federation — google-github-actions/auth exchanges the
#     job's OIDC token and exports GOOGLE_APPLICATION_CREDENTIALS (no static
#     key anywhere). supply's json_key accepts that credentials file directly.
#  2. Raw service-account JSON from env (secretspec <- OpenBao) for local runs.
def play_auth_args
  ambient = ENV["GOOGLE_APPLICATION_CREDENTIALS"]
  if ambient && File.exist?(ambient)
    { json_key: ambient }
  else
    { json_key_data: ENV.fetch("GOOGLE_SERVICE_ACCOUNT_KEY_JSON") }
  end
end

platform :ios do
  desc "Create/renew the dist cert + App Store profile via the ASC key (run locally; then store in OpenBao — runbook D)"
  lane :certs do
    FileUtils.mkdir_p(SIGNING_DIR)
    # Apple Distribution certificate: generates a private key locally, saves
    # .cer + .p12 (passwordless) into SIGNING_DIR, installs into the keychain.
    cert(
      api_key: asc_api_key,
      development: false,
      output_path: SIGNING_DIR,
    )
    # App Store provisioning profile bound to that cert + the bundle id.
    sigh(
      api_key: asc_api_key,
      provisioning_name: IOS_PROFILE_NAME,
      force: true,
      output_path: SIGNING_DIR,
      filename: "appstore.mobileprovision",
    )
    UI.success("Now store the signing material in OpenBao + GitHub Secrets (runbook section D):")
    UI.message("  FRESSH_IOS_CERT_P12_BASE64  = base64 of #{SIGNING_DIR}/<cert-id>.p12")
    UI.message("  FRESSH_IOS_PROFILE_BASE64   = base64 of #{SIGNING_DIR}/appstore.mobileprovision")
  end

  desc "Archive a signed release IPA -> build/fressh-ios.ipa (expo prebuild -p ios must have run)"
  lane :build do
    # Materialize signing material from env (secretspec <- OpenBao / GH Secrets),
    # the iOS twin of signed-build.ts's keystore handling.
    FileUtils.mkdir_p(SIGNING_DIR)
    p12_path = File.join(SIGNING_DIR, "dist.p12")
    profile_path = File.join(SIGNING_DIR, "appstore.mobileprovision")
    File.binwrite(p12_path, Base64.decode64(ENV.fetch("FRESSH_IOS_CERT_P12_BASE64")))
    File.binwrite(profile_path, Base64.decode64(ENV.fetch("FRESSH_IOS_PROFILE_BASE64")))

    # Sign from a dedicated keychain — locally AND on CI. Importing into the
    # login keychain breaks non-interactive codesign with errSecInternalComponent
    # (its keys lack the apple-tool: partition-list entry, and fixing that
    # requires the user's login password). import_certificate sets the partition
    # list correctly when given the keychain password.
    keychain = "fressh-build"
    # macOS names the file <name>-db or <name>.keychain-db depending on version.
    existing = Dir.glob(File.expand_path("~/Library/Keychains/#{keychain}*"))
    delete_keychain(name: keychain) unless existing.empty?
    create_keychain(
      name: keychain,
      password: "",
      unlock: true,
      timeout: 3600,
      add_to_search_list: true,
    )
    import_certificate(
      certificate_path: p12_path,
      certificate_password: IOS_P12_PASSWORD,
      keychain_name: keychain,
      keychain_password: "",
    )
    install_provisioning_profile(path: profile_path)

    update_code_signing_settings(
      path: File.join(MOBILE_DIR, "ios", "Fressh.xcodeproj"),
      use_automatic_signing: false,
      code_sign_identity: "Apple Distribution",
      team_id: APPLE_TEAM_ID,
      profile_name: IOS_PROFILE_NAME,
      targets: ["Fressh"],
    )
    # Stamp a fresh, monotonic CFBundleVersion from App Store Connect, overriding the
    # semver-derived default expo prebuild baked in from app.config.ts. TestFlight
    # rejects a re-used build number within a marketing version, so a semver- (or
    # canary-) derived number breaks re-runs; latest-on-ASC + 1 is always unique +
    # increasing. agvtool works because expo's project uses VERSIONING_SYSTEM =
    # apple-generic (CFBundleVersion is rewritten across all targets).
    increment_build_number(
      xcodeproj: File.join(MOBILE_DIR, "ios", "Fressh.xcodeproj"),
      build_number: (latest_ios_build_number + 1).to_s,
    )
    build_app(
      workspace: File.join(MOBILE_DIR, "ios", "Fressh.xcworkspace"),
      scheme: "Fressh",
      configuration: "Release",
      export_method: "app-store",
      output_directory: File.join(MOBILE_DIR, "build"),
      output_name: "fressh-ios.ipa",
    )
  end

  desc "Upload build/fressh-ios.ipa to TestFlight (internal testing — no Apple review)"
  lane :beta do
    pilot(
      api_key: asc_api_key,
      ipa: File.join(MOBILE_DIR, "build", "fressh-ios.ipa"),
      changelog: release_notes,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
    )
  end

  desc "Promote: submit the already-uploaded TestFlight build for App Review + auto-release"
  lane :release do |options|
    version = marketing_version(options[:version] || app_version)
    # deliver reads What's New from fastlane/metadata/en-US/release_notes.txt.
    notes_path = File.join(__dir__, "metadata", "en-US", "release_notes.txt")
    File.write(notes_path, release_notes)
    deliver(
      api_key: asc_api_key,
      app_version: version,
      # Build numbers are ASC-assigned (latest+1), not semver-predictable — promote
      # the latest uploaded build for this marketing version.
      build_number: latest_ios_build_number(version).to_s,
      skip_binary_upload: true, # promote the existing TestFlight build
      skip_screenshots: true, # flip false once fastlane/screenshots is seeded
      submit_for_review: true,
      automatic_release: true,
      precheck_include_in_app_purchases: false,
      force: true, # no interactive HTML preview in CI
    )
  end
end

platform :android do
  desc "Upload build/fressh-android.aab to the Play internal testing track"
  lane :beta do
    supply(
      **play_auth_args,
      track: "internal",
      aab: File.join(MOBILE_DIR, "build", "fressh-android.aab"),
      release_status: "completed",
      # Listing metadata/screenshots are owned by the promote/listing flow;
      # betas only ship the binary + its changelog
      # (metadata/android/en-US/changelogs/<versionCode>.txt).
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false,
    )
  end

  desc "Print + stage the next Play versionCode (max across tracks + 1) for canary/rc builds (store-derived, collision-free). Writes build/next-version-code.txt for CI to read into FRESSH_VERSION_CODE before prebuild."
  lane :next_version_code do
    tracks = %w[internal alpha beta production]
    codes = tracks.flat_map do |track|
      google_play_track_version_codes(**play_auth_args, track: track)
    rescue StandardError => e
      UI.important("google_play_track_version_codes(#{track}) failed: #{e.message}; treating as empty")
      []
    end
    next_code = (codes.map(&:to_i).max || 0) + 1
    out = File.join(MOBILE_DIR, "build", "next-version-code.txt")
    FileUtils.mkdir_p(File.dirname(out))
    File.write(out, next_code.to_s)
    UI.success("next android versionCode #{next_code} -> #{out}")
    next_code
  end

  desc "Promote: move a versionCode from the internal track to production (same artifact)"
  lane :promote do |options|
    version = options[:version] || app_version
    supply(
      **play_auth_args,
      track: "internal",
      track_promote_to: "production",
      version_code: version_code(version),
      # Promotion only — never re-upload binaries or touch the listing here.
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true,
      # Staged rollout option once there are real users:
      # track_promote_release_status: "inProgress", rollout: "0.1",
    )
  end
end
