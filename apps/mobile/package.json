{
  "name": "@fressh/mobile",
  "version": "0.0.4",
  "private": true,
  "main": "expo-router/entry",
  "type": "module",
  "scripts": {
    "oxlint:fix": "oxlint -c .oxlintrc.json --type-aware --type-check --report-unused-disable-directives-severity=error --fix .",
    "oxlint:check": "oxlint -c .oxlintrc.json --type-aware --type-check --report-unused-disable-directives-severity=error .",
    "tsgo:check": "tsgo --noEmit",
    "android": "expo run:android --port 8082",
    "ios": "expo run:ios --port 8081",
    "dev:android:release": "expo run:android --port 8082 --variant release",
    "dev:ios:release": "expo run:ios --port 8081 --variant release",
    "build:signed:aab": "tsx scripts/signed-build.ts",
    "build:signed:apk": "tsx scripts/signed-build.ts --format apk",
    "build:aab": "cd android && ./gradlew bundleRelease",
    "build:apk": "cd android && ./gradlew assembleRelease",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "expo:install:fix": "expo install --fix",
    "expo:doctor": "bunx expo-doctor@latest || true",
    "maestro:test": "maestro test test/e2e/",
    "adb:logs": "while ! adb logcat --pid=$(adb shell pidof -s dev.fressh.app); do sleep 1; done",
    "release": "GITHUB_TOKEN=$(gh auth token) release-it",
    "release:dry": "release-it --dry-run"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@fressh/assets": "workspace:*",
    "@fressh/react-native-uniffi-russh": "workspace:*",
    "@fressh/react-native-xtermjs-webview": "workspace:*",
    "@react-native-segmented-control/segmented-control": "2.5.7",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.4",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-form": "^1.27.7",
    "@tanstack/react-query": "^5.90.16",
    "date-fns": "^4.1.0",
    "expo": "~54.0.31",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-glass-effect": "^0.1.8",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.21",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "catalog:",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-logs": "^5.5.0",
    "react-native-mmkv": "^4.1.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.2",
    "react-native-webview": "catalog:",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "catalog:",
    "@types/react": "catalog:",
    "cmd-ts": "^0.14.3",
    "cross-env": "catalog:",
    "release-it": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@dylankenneally/react-native-ssh-sftp"
        ]
      }
    }
  }
}
