{
	"name": "@fressh/mobile",
	"version": "0.0.4",
	"private": true,
	"type": "module",
	"main": "expo-router/entry",
	"scripts": {
		"tsgo:check": "tsgo --noEmit",
		"android": "expo run:android --port 8082",
		"ios": "expo run:ios --port 8081",
		"dev:android:release": "expo run:android --port 8082 --variant release",
		"dev:ios:release": "expo run:ios --port 8081 --variant release",
		"build:signed:aab": "tsx scripts/signed-build.ts",
		"build:signed:apk": "tsx scripts/signed-build.ts --format apk",
		"build:aab": "cd android && ./gradlew bundleRelease",
		"build:apk": "cd android && ./gradlew assembleRelease",
		"prebuild": "expo prebuild",
		"prebuild:clean": "expo prebuild --clean",
		"expo:install:fix": "expo install --fix",
		"expo:doctor": "bunx expo-doctor@latest || true",
		"maestro:test": "maestro test test/e2e/",
		"adb:logs": "while ! adb logcat --pid=$(adb shell pidof -s dev.fressh.app); do sleep 1; done",
		"release": "GITHUB_TOKEN=$(gh auth token) release-it",
		"release:dry": "release-it --dry-run"
	},
	"dependencies": {
		"@expo/vector-icons": "^15.0.3",
		"@fressh/assets": "workspace:*",
		"@fressh/react-native-terminal": "workspace:*",
		"@react-native-segmented-control/segmented-control": "2.5.7",
		"@effect/atom-react": "catalog:",
		"@shopify/flash-list": "2.0.2",
		"@tanstack/react-form": "^1.33.0",
		"date-fns": "^4.4.0",
		"effect": "catalog:",
		"expo": "~56.0.3",
		"expo-clipboard": "~56.0.3",
		"expo-constants": "~56.0.14",
		"expo-crypto": "~56.0.4",
		"expo-dev-client": "~56.0.14",
		"expo-document-picker": "~56.0.4",
		"expo-file-system": "~56.0.7",
		"expo-font": "~56.0.5",
		"expo-glass-effect": "~56.0.4",
		"expo-haptics": "~56.0.3",
		"expo-image": "~56.0.9",
		"expo-linking": "~56.0.11",
		"expo-router": "~56.2.5",
		"expo-splash-screen": "~56.0.9",
		"expo-status-bar": "~56.0.4",
		"expo-symbols": "~56.0.5",
		"expo-system-ui": "~56.0.5",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-native": "catalog:",
		"react-native-gesture-handler": "~2.31.2",
		"react-native-keychain": "10.0.0",
		"react-native-keyboard-controller": "1.21.6",
		"react-native-logs": "^5.6.0",
		"react-native-mmkv": "4.3.1",
		"react-native-nitro-modules": "0.35.9",
		"react-native-reanimated": "~4.3.1",
		"react-native-safe-area-context": "~5.7.0",
		"react-native-screens": "4.25.2",
		"react-native-web": "~0.21.2",
		"react-native-webview": "catalog:",
		"react-native-worklets": "~0.8.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@release-it/conventional-changelog": "catalog:",
		"@types/react": "catalog:",
		"cmd-ts": "^0.15.0",
		"cross-env": "catalog:",
		"release-it": "catalog:",
		"tsx": "^4.22.4",
		"typescript": "catalog:"
	},
	"expo": {
		"install": {
			"exclude": [
				"react",
				"react-dom",
				"typescript"
			]
		},
		"doctor": {
			"reactNativeDirectoryCheck": {
				"exclude": [
					"@dylankenneally/react-native-ssh-sftp"
				]
			}
		}
	}
}
