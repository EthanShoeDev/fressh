{
	"extends": ["expo/tsconfig.base", "../../tsconfig.base.json"],
	"compilerOptions": {
		"types": ["node"],
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"noImplicitOverride": true,
		"allowJs": true,
		"strictNullChecks": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
		"expo-env.d.ts",
		"eslint.config.js",
		".release-it.ts"
	]
}
