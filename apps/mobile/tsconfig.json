{
	"extends": ["expo/tsconfig.base", "../../tsconfig.base.json"],
	"compilerOptions": {
		"types": ["node", "bun"],
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"noImplicitOverride": true,
		"allowJs": true,
		"strictNullChecks": true,
		"paths": {
			"@/*": ["./src/*"],
			"react-native-animated-glow": [
				"../../node_modules/react-native-animated-glow/lib/typescript/index"
			]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
		"expo-env.d.ts",
		"eslint.config.js"
	]
}
