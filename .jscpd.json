{
	"pattern": "**/*",
	"ignore": [
		"**/.expo/**",
		"**/.turbo/**",
		"**/mnt/**",
		"**/dist/**",
		"**/dist-internal/**",
		"**/node_modules/**",
		"**/android/**",
		"**/ios/**",
		"**/generated/**",
		"**/rust/target/**",
		"**/eslint.config.js",
		"**/docs/cloned-repos-as-docs/**",
		"**/submodules/**/*",
		"**/package.json",
		"**/README.md",
		"**/AGENTS.md",
		"**/CLAUDE.md",
		"**/.github/**",
		"**/.claude/**",
		"**/.cursor/**",
		"**/.opencode/**",
		"**/.agents/**",
		"**/*.gen.*",
		"**/*.snapshot.json",
		"**/*.hbs"
	],
	"threshold": 0,
	"minTokens": 50,
	"minLines": 33,
	"maxLines": 1000,
	"maxSize": "100kb"
}
