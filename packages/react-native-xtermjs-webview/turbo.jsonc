{
	"extends": ["//"],
	"tasks": {
		// Override build to depend on both vite builds
		"build": {
			"dependsOn": ["vite:build:internal", "vite:build"],
		},

		// Package-specific tasks
		"vite:build": {
			"inputs": ["src/**", "vite.config.ts"],
			"dependsOn": ["vite:build:internal"],
			"outputs": ["dist/**"],
		},
		"vite:build:internal": {
			"inputs": ["src-internal/**", "index.html", "vite.config.internal.ts"],
			"outputs": ["dist-internal/**"],
		},
	},
}
