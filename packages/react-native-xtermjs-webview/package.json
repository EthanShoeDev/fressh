{
  "name": "@fressh/react-native-xtermjs-webview",
  "private": false,
  "version": "0.0.8",
  "license": "MIT",
  "type": "module",
  "files": [
    "src",
    "dist",
    "dist-internal",
    "*.config.*",
    "tsconfig*.json",
    "*.md",
    "*.html"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EthanShoeDev/fressh.git"
  },
  "bugs": {
    "url": "https://github.com/EthanShoeDev/fressh/issues"
  },
  "homepage": "https://github.com/EthanShoeDev/fressh#readme",
  "keywords": [
    "react-native",
    "xterm",
    "webview",
    "terminal",
    "ssh",
    "expo",
    "android",
    "ios"
  ],
  "scripts": {
    "build": "bun run vite:build",
    "dev": "bun run vite:dev",
    "oxfmt:fix": "oxfmt --write",
    "oxfmt:check": "oxfmt --check",
    "oxlint:fix": "oxlint -c .oxlintrc.json --type-aware --type-check --fix .",
    "oxlint:check": "oxlint -c .oxlintrc.json --type-aware --type-check .",
    "tsgo:check": "tsgo --noEmit",
    "vite:build": "tsc -b && vite build",
    "vite:build:internal": "tsc -b && vite build --config vite.config.internal.ts",
    "vite:dev": "vite --config vite.config.internal.ts",
    "vite:preview": "vite preview",
    "release-it:release": "GITHUB_TOKEN=$(gh auth token) release-it",
    "release-it:dry": "release-it --dry-run"
  },
  "dependencies": {
    "js-base64": "^3.7.8"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-native-webview": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "cross-env": "catalog:",
    "js-base64": "^3.7.8",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native-webview": "catalog:",
    "release-it": "catalog:",
    "typescript": "catalog:",
    "vite": "8.0.0-beta.7",
    "vite-plugin-dts": "5.0.0-beta.6",
    "vite-plugin-singlefile": "^2.3.0"
  }
}