{
	"name": "@fressh/react-native-xtermjs-webview",
	"version": "0.0.8",
	"private": false,
	"keywords": [
		"android",
		"expo",
		"ios",
		"react-native",
		"ssh",
		"terminal",
		"webview",
		"xterm"
	],
	"homepage": "https://github.com/EthanShoeDev/fressh#readme",
	"bugs": {
		"url": "https://github.com/EthanShoeDev/fressh/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/EthanShoeDev/fressh.git"
	},
	"files": [
		"src",
		"dist",
		"dist-internal",
		"*.config.*",
		"tsconfig*.json",
		"*.md",
		"*.html"
	],
	"type": "module",
	"exports": {
		".": "./dist/index.js"
	},
	"scripts": {
		"build": "bun run vite:build",
		"dev": "bun run vite:dev",
		"tsgo:check": "tsgo --noEmit",
		"vite:build": "tsc -b && vite build",
		"vite:build:internal": "tsc -b && vite build --config vite.config.internal.ts",
		"vite:dev": "vite --config vite.config.internal.ts",
		"vite:preview": "vite preview",
		"release-it:release": "GITHUB_TOKEN=$(gh auth token) release-it",
		"release-it:dry": "release-it --dry-run"
	},
	"dependencies": {
		"js-base64": "^3.7.8"
	},
	"devDependencies": {
		"@types/react": "catalog:",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"cross-env": "catalog:",
		"js-base64": "^3.7.8",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-native-webview": "catalog:",
		"release-it": "catalog:",
		"typescript": "catalog:",
		"vite": "^7.3.2",
		"vite-plugin-dts": "5.0.2",
		"vite-plugin-singlefile": "^2.3.3"
	},
	"peerDependencies": {
		"react": "catalog:",
		"react-native-webview": "catalog:"
	}
}
