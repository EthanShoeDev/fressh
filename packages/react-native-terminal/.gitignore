# Build outputs
lib/
rust/target/
android/build/
android/.cxx/
android/src/main/jniLibs/
ios/build/
# shim_uniffi.xcframework (~114MB) is built from OUR rust by `build:ios` and
# changes every code edit, so it's a build output: NOT committed (turbo caches it;
# a clean checkout restores it from cache or rebuilds via the `^build:ios` edge).
# The ANGLE xcframeworks (libEGL/libGLESv2, ~19MB) are stable third-party prebuilts
# vendored via fetch-angle.sh — they ARE committed, so `git clean -fxd` can't wipe
# them and a clean checkout renders without a network fetch. (Was `*.xcframework/`,
# which silently let `git clean` blank the iOS renderer.)
shim_uniffi.xcframework/

# Codegen outputs (regenerated by ubrn / nitrogen)
cpp/generated/
src/generated/
nitrogen/generated/
android/generated/

# The alacritty fork lives at rust/vendor/alacritty as a git SUBMODULE (tracked
# via .gitmodules — do NOT ignore it). Only its build output:
rust/vendor/alacritty/target/
rust/vendor/crossfont/target/
