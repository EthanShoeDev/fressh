{
	"name": "@fressh/react-native-uniffi-russh",
	"version": "0.0.5",
	"description": "Uniffi bindings for russh",
	"keywords": [
		"android",
		"expo",
		"ios",
		"react-native",
		"russh",
		"rust",
		"ssh",
		"uniffi"
	],
	"homepage": "https://github.com/EthanShoeDev/fressh#readme",
	"bugs": {
		"url": "https://github.com/EthanShoeDev/fressh/issues"
	},
	"license": "MIT",
	"author": "EthanShoeDev <13422990+EthanShoeDev@users.noreply.github.com> (https://github.com/EthanShoeDev)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/EthanShoeDev/fressh.git"
	},
	"files": [
		"lib",
		"android",
		"ios",
		"src",
		"cpp",
		"rust",
		"*.podspec",
		"*.xcframework/**",
		"react-native.config.js",
		"*.md",
		"*.config.*",
		"tsconfig*.json",
		"LICENSE"
	],
	"type": "module",
	"main": "./lib/module/api.js",
	"types": "./lib/typescript/src/api.d.ts",
	"exports": {
		".": {
			"types": "./lib/typescript/src/api.d.ts",
			"default": "./lib/module/api.js"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "bun run bob:build",
		"test": "bun run jest:test",
		"tsgo:check": "tsgo --noEmit",
		"ubrn:build:ios": "ubrn build ios --and-generate --release",
		"ubrn:build:android": "ubrn build android --and-generate --release",
		"tsx:build:native": "tsx scripts/native-build.ts",
		"bob:build": "bob build",
		"cargo:lint:fix": "cd rust/uniffi-russh && just lint",
		"cargo:lint:check": "cd rust/uniffi-russh && just lint-check",
		"cargo:fmt:fix": "cd rust/uniffi-russh && just fmt",
		"cargo:fmt:check": "cd rust/uniffi-russh && just fmt-check",
		"cargo:update": "cd rust/uniffi-russh && just update-deps",
		"jest:test": "jest",
		"release-it:release": "GITHUB_TOKEN=$(gh auth token) release-it",
		"release-it:dry": "release-it --dry-run"
	},
	"dependencies": {
		"uniffi-bindgen-react-native": "github:jhugman/uniffi-bindgen-react-native#main"
	},
	"devDependencies": {
		"@react-native-community/cli": "20.1.3",
		"@react-native/babel-preset": "0.85.3",
		"@release-it/conventional-changelog": "catalog:",
		"@types/jest": "^30.0.0",
		"@types/react": "catalog:",
		"cross-env": "catalog:",
		"jest": "^30.4.2",
		"react": "catalog:",
		"react-native": "catalog:",
		"react-native-builder-bob": "^0.41.0",
		"release-it": "catalog:",
		"turbo": "^2.9.16",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"react": "catalog:",
		"react-native": "catalog:"
	},
	"jest": {
		"modulePathIgnorePatterns": [
			"<rootDir>/example/node_modules",
			"<rootDir>/lib/"
		],
		"preset": "react-native"
	},
	"codegenConfig": {
		"name": "UniffiRusshSpec",
		"type": "modules",
		"jsSrcsDir": "src",
		"android": {
			"javaPackageName": "com.uniffirussh"
		}
	},
	"create-react-native-library": {
		"languages": "kotlin-objc",
		"type": "turbo-module",
		"version": "0.54.3"
	},
	"react-native-builder-bob": {
		"source": "src",
		"output": "lib",
		"targets": [
			[
				"module",
				{
					"esm": true
				}
			],
			[
				"typescript",
				{
					"project": "tsconfig.build.json"
				}
			]
		]
	}
}
