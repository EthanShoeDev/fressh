     if (surface) {
       wgpu::SurfaceTexture surfaceTexture;
       surface.GetCurrentTexture(&surfaceTexture);
-      return surfaceTexture.texture;
-    } else {
+      if (surfaceTexture.texture != nullptr) {
+        return surfaceTexture.texture;
+      }
+    } else if (texture != nullptr) {
       return texture;
     }
+    // The surface was torn down mid-frame (e.g. Android surfaceDestroyed on a
+    // tab switch) while a worklet render loop is still presenting. Hand back a
+    // throwaway texture so getCurrentTexture().createView() renders into a
+    // discarded target instead of dereferencing null in Dawn — which crashed
+    // the process (SIGSEGV, or SIGABRT once guarded with a throw). Only reached
+    // when the live surface yields no texture, so steady-state rendering on a
+    // focused screen is untouched. See docs/bun-patches.md.
+    if (config.device != nullptr &&
+        config.format != wgpu::TextureFormat::Undefined) {
+      wgpu::TextureDescriptor fallback;
+      fallback.format = config.format;
+      fallback.size.width = config.width > 0 ? config.width : 1;
+      fallback.size.height = config.height > 0 ? config.height : 1;
+      fallback.usage = wgpu::TextureUsage::RenderAttachment |
+                       wgpu::TextureUsage::CopySrc |
+                       wgpu::TextureUsage::TextureBinding;
+      return config.device.CreateTexture(&fallback);
+    }
+    return nullptr;
   }
 
   // True when an on-screen wgpu::Surface is attached (vs offscreen texture).
