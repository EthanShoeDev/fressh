{
	"name": "fressh",
	"version": "workspace:*",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"react": "19.2.3",
			"react-dom": "19.2.3",
			"react-native": "0.85.3",
			"react-native-webview": "13.16.1",
			"@types/react": "~19.2.14",
			"typescript": "~5.9.3",
			"cross-env": "^10.1.0",
			"release-it": "^20.2.0",
			"@release-it/conventional-changelog": "^11.0.1",
			"tsdown": "^0.22.1",
			"effect": "https://pkg.pr.new/EthanShoeDev/effect/effect@c8b2ef4",
			"@effect/platform": "https://pkg.pr.new/EthanShoeDev/effect/@effect/platform@c8b2ef4",
			"@effect/platform-bun": "https://pkg.pr.new/EthanShoeDev/effect/@effect/platform-bun@c8b2ef4",
			"@effect/cli": "https://pkg.pr.new/EthanShoeDev/effect/@effect/cli@c8b2ef4"
		}
	},
	"type": "module",
	"scripts": {
		"oxfmt:fix": "oxfmt --write",
		"oxfmt:check": "oxfmt --check",
		"nix:fmt": "nix fmt flake.nix",
		"nix:fmt:check": "nix fmt flake.nix -- -c",
		"oxlint:fix": "oxlint -c oxlint.config.ts --type-aware --type-check --report-unused-disable-directives-severity=error --fix .",
		"oxlint:check": "oxlint -c oxlint.config.ts --type-aware --type-check --report-unused-disable-directives-severity=error .",
		"oxlint:unsafe:fix": "oxlint -c oxlint.config.ts --type-aware --type-check --report-unused-disable-directives-severity=error --fix-dangerously .",
		"jscpd:check": "cross-env NODE_OPTIONS=--max-old-space-size=8192 jscpd --config .jscpd.json",
		"knip:check": "knip",
		"knip:fix": "knip --fix",
		"catalog:check": "bun scripts/catalog-check.ts",
		"catalog:fix": "bun scripts/catalog-check.ts --fix",
		"ncu:interactive": "bunx npm-check-updates --interactive --format group -ws --root",
		"prepare": "effect-tsgo patch"
	},
	"devDependencies": {
		"@effect/cli": "catalog:",
		"@effect/platform": "catalog:",
		"@effect/platform-bun": "catalog:",
		"@effect/tsgo": "0.13.0",
		"@types/semver": "^7.7.1",
		"@typescript/native-preview": "7.0.0-dev.20260601.1",
		"cross-env": "catalog:",
		"effect": "catalog:",
		"eslint": "^10.4.1",
		"globby": "^16.2.0",
		"jscpd": "^4.2.4",
		"knip": "^6.15.0",
		"oxfmt": "0.53.0",
		"oxlint": "1.68.0",
		"oxlint-tsgolint": "0.23.0",
		"semver": "^7.8.1",
		"tsx": "^4.22.4",
		"turbo": "^2.9.16",
		"typescript": "catalog:"
	},
	"overrides": {
		"react-native-nitro-modules": "0.35.9",
		"@effect/cli": "https://pkg.pr.new/EthanShoeDev/effect/@effect/cli@c8b2ef4",
		"@effect/platform": "https://pkg.pr.new/EthanShoeDev/effect/@effect/platform@c8b2ef4",
		"@effect/platform-bun": "https://pkg.pr.new/EthanShoeDev/effect/@effect/platform-bun@c8b2ef4",
		"@effect/printer": "https://pkg.pr.new/EthanShoeDev/effect/@effect/printer@c8b2ef4",
		"@effect/printer-ansi": "https://pkg.pr.new/EthanShoeDev/effect/@effect/printer-ansi@c8b2ef4",
		"effect": "https://pkg.pr.new/EthanShoeDev/effect/effect@c8b2ef4"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "bun@1.3.6",
	"patchedDependencies": {
		"nitrogen@0.35.9": "patches/nitrogen@0.35.9.patch"
	}
}
