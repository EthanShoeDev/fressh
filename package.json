{
	"name": "fressh",
	"version": "workspace:*",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"fmt:root": "oxfmt --write",
		"fmt:check:root": "oxfmt --check",
		"fmt:root:nix": "nix fmt flake.nix",
		"fmt:check:root:nix": "nix fmt flake.nix -- -c",
		"lint:root": "oxlint -c .oxlintrc.json --type-aware --type-check .",
		"lint:fix:root": "oxlint -c .oxlintrc.json --type-aware --type-check --fix .",
		"syncpack:fix": "syncpack list-mismatches || (syncpack fix-mismatches && bun i)",
		"syncpack:check": "syncpack list-mismatches",
		"jscpd:check": "cross-env NODE_OPTIONS=--max-old-space-size=8192 jscpd --config .jscpd.json",
		"knip:check": "knip",
		"knip:fix:danger": "knip --fix",
		"update:all": "syncpack update",
		"update:all:alt": "bunx npm-check-updates --interactive --format group -ws --root"
	},
	"devDependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260109.1",
		"cross-env": "^10.0.0",
		"globby": "^14.1.0",
		"jscpd": "^4.0.5",
		"knip": "^5.63.1",
		"oxfmt": "0.23.0",
		"oxlint": "1.38.0",
		"oxlint-tsgolint": "0.11.0",
		"syncpack": "^13.0.4",
		"tsx": "^4.20.5",
		"turbo": "^2.5.7",
		"typescript": "~5.9.2",
		"ultracite": "7.0.10"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "bun@1.3.5"
}
