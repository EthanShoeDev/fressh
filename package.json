{
	"name": "fressh",
	"version": "workspace:*",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"react": "19.2.3",
			"react-dom": "19.2.3",
			"react-native": "0.85.3",
			"react-native-webview": "13.16.1",
			"@types/react": "~19.2.14",
			"@types/react-dom": "^19.2.3",
			"typescript": "~5.9.3",
			"cross-env": "^10.1.0",
			"tsdown": "^0.22.1",
			"effect": "4.0.0-beta.78",
			"@effect/platform-bun": "4.0.0-beta.78",
			"@effect/atom-react": "4.0.0-beta.78",
			"uniwind": "1.8.0",
			"tailwindcss": "4.3.0"
		}
	},
	"type": "module",
	"scripts": {
		"oxfmt:fix": "oxfmt --write",
		"oxfmt:check": "oxfmt --check",
		"nix:fmt": "nix fmt flake.nix",
		"nix:fmt:check": "nix fmt flake.nix -- -c",
		"oxlint:fix": "oxlint -c oxlint.config.ts --type-aware --type-check --report-unused-disable-directives-severity=error --fix .",
		"oxlint:check": "oxlint -c oxlint.config.ts --type-aware --type-check --report-unused-disable-directives-severity=error .",
		"oxlint:unsafe:fix": "oxlint -c oxlint.config.ts --type-aware --type-check --report-unused-disable-directives-severity=error --fix-dangerously .",
		"jscpd:check": "cross-env NODE_OPTIONS=--max-old-space-size=8192 jscpd --config .jscpd.json",
		"knip:check": "knip",
		"knip:fix": "knip --fix",
		"catalog:check": "bun scripts/catalog-check.ts",
		"catalog:fix": "bun scripts/catalog-check.ts --fix",
		"changeset": "changeset",
		"version": "changeset version && bun install --lockfile-only",
		"tag": "changeset tag",
		"ncu:interactive": "bunx npm-check-updates --interactive --format group -ws --root",
		"prepare": "effect-tsgo patch"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@effect/platform-bun": "catalog:",
		"@effect/tsgo": "0.13.0",
		"@types/semver": "^7.7.1",
		"@typescript/native-preview": "7.0.0-dev.20260601.1",
		"cross-env": "catalog:",
		"effect": "catalog:",
		"eslint": "^10.4.1",
		"globby": "^16.2.0",
		"jscpd": "^4.2.4",
		"knip": "^6.15.0",
		"oxfmt": "0.53.0",
		"oxlint": "1.68.0",
		"oxlint-tsgolint": "0.23.0",
		"semver": "^7.8.1",
		"tsx": "^4.22.4",
		"turbo": "^2.9.16",
		"typescript": "catalog:"
	},
	"overrides": {
		"react-native-nitro-modules": "0.35.9"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "bun@1.3.6",
	"patchedDependencies": {
		"nitrogen@0.35.9": "patches/nitrogen@0.35.9.patch",
		"expo-modules-jsi@56.0.8": "patches/expo-modules-jsi@56.0.8.patch",
		"expo-modules-core@56.0.15": "patches/expo-modules-core@56.0.15.patch"
	},
	"trustedDependencies": [
		"@shopify/react-native-skia"
	]
}
